{
    "name": "fiken-mcp",
    "version": "1.0.0",
    "description": "MCP server for the Fiken accounting API",
    "type": "module",
    "main": "build/index.js",
    "bin": {
        "fiken-mcp": "build/index.js"
    },
    "files": [
        "build"
    ],
    "scripts": {
        "build": "tsc",
        "start": "node build/index.js",
        "dev": "tsx src/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "pnpm build && changeset publish",
        "prepare": "husky"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/gronnmann/fiken-mcp.git"
    },
    "homepage": "https://github.com/gronnmann/fiken-mcp",
    "bugs": {
        "url": "https://github.com/gronnmann/fiken-mcp/issues"
    },
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.11.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.6",
        "@semantic-release/npm": "^13.1.5",
        "@types/node": "^22.0.0",
        "@vitest/coverage-v8": "^3.0.0",
        "husky": "^9.1.7",
        "prettier": "^3.8.1",
        "semantic-release": "^25.0.3",
        "tsx": "^4.19.0",
        "typescript": "^5.8.0",
        "vitest": "^3.0.0"
    },
    "engines": {
        "node": ">=18"
    }
}
